generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  userId       BigInt       @id @default(autoincrement()) @map("user_id")
  phoneHash    String       @map("phone_hash") @db.VarChar(64)
  role         UserRole
  city         String?      @db.VarChar(50)
  district     String?      @db.VarChar(100)
  memberLevel  MemberLevel  @default(free) @map("member_level")
  memberExpire DateTime?    @map("member_expire")
  status       UserStatus   @default(active)
  captainLevel CaptainLevel @default(normal) @map("captain_level")
  maskedPhone  String?      @map("masked_phone") @db.VarChar(20)
  createdAt    DateTime     @default(now()) @map("created_at")
  taskViewCount Int         @default(0) @map("task_view_count")
  taskAcceptCount Int       @default(0) @map("task_accept_count")
  lastIp       String?      @db.VarChar(50) @map("last_ip")
  inviteCode   String?      @unique @db.VarChar(10) @map("invite_code")
  contents     Content[]
  resources    Resource[]
  doppelganger CyberDoppelganger?

  @@map("users")
}

model Resource {
  resourceId   BigInt         @id @default(autoincrement()) @map("resource_id")
  userId       BigInt         @map("user_id")
  resourceType ResourceType   @map("resource_type")
  tags         Json
  areaCode     String?        @map("area_code") @db.VarChar(20)
  priceRange   Json?          @map("price_range")
  status       ResourceStatus @default(pending)
  verifiedAt   DateTime?      @map("verified_at")
  lastUpdate   DateTime?      @map("last_update")
  matches      Match[]
  user         User           @relation(fields: [userId], references: [userId])

  @@index([userId], map: "resources_user_id_fkey")
  @@map("resources")
}

model Match {
  matchId    BigInt      @id @default(autoincrement()) @map("match_id")
  needId     BigInt      @map("need_id")
  resourceId BigInt      @map("resource_id")
  matchScore Decimal     @map("match_score") @db.Decimal(5, 2)
  status     MatchStatus
  pushTime   DateTime?   @map("push_time")
  feedback   Int?        @db.TinyInt
  resource   Resource    @relation(fields: [resourceId], references: [resourceId])

  @@index([resourceId], map: "matches_resource_id_fkey")
  @@index([needId], map: "need_id")
  @@map("matches")
}

model CaptainCommission {
  commissionId     BigInt           @id @default(autoincrement()) @map("commission_id")
  captainId        BigInt           @map("captain_id")
  orderId          BigInt           @map("order_id")
  orderAmount      Decimal          @map("order_amount") @db.Decimal(10, 2)
  commissionRate   Decimal          @map("commission_rate") @db.Decimal(5, 2)
  commissionAmount Decimal          @map("commission_amount") @db.Decimal(10, 2)
  status           CommissionStatus
  confirmAt        DateTime?        @map("confirm_at")

  @@index([captainId], map: "idx_commission_captain_id")
  @@index([orderId], map: "order_id")
  @@map("captain_commissions")
}

model InviteRecord {
  recordId   BigInt   @id @default(autoincrement()) @map("record_id")
  inviterId  BigInt   @map("inviter_id")
  inviteeId  BigInt   @map("invitee_id")
  inviteCode String   @map("invite_code") @db.VarChar(8)
  isValid    Boolean  @default(true) @map("is_valid")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([inviteeId], map: "invitee_id")
  @@index([inviterId], map: "inviter_id")
  @@map("invite_records")
}

model Content {
  contentId      BigInt        @id @default(autoincrement()) @map("content_id")
  userId         BigInt        @map("user_id")
  contentType    ContentType   @map("content_type")
  contentBody    String        @map("content_body") @db.Text
  targetPlatform String        @map("target_platform") @db.VarChar(50)
  status         ContentStatus @default(draft)
  stats          Json?
  publishedAt    DateTime?     @map("published_at")
  user           User          @relation(fields: [userId], references: [userId])

  @@index([userId], map: "contents_user_id_fkey")
  @@map("contents")
}

model Announcement {
  noticeId  BigInt   @id @default(autoincrement()) @map("notice_id")
  content   String   @db.Text
  publisher String   @default("admin") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("announcements")
}

enum UserRole {
  service
  resource
  both
}

enum MemberLevel {
  free
  monthly
  yearly
  lifetime
}

enum UserStatus {
  active
  banned
  frozen
}

enum ResourceType {
  skill
  location
  account
  time
}

enum ResourceStatus {
  pending
  active
  inactive
  rejected
}

enum MatchStatus {
  pushed
  viewed
  confirmed
  done
  invalid
}

enum CommissionStatus {
  pending
  active
  paid
  invalid
}

enum ContentType {
  card
  post
  video_script
  poster
}

enum ContentStatus {
  draft
  pending
  published
  rejected
}

enum CaptainLevel {
  normal
  advanced
  gold
}

model CyberDoppelganger {
  doppelgangerId BigInt             @id @default(autoincrement()) @map("doppelganger_id")
  userId         BigInt             @unique @map("user_id")
  balance        Decimal            @default(0) @db.Decimal(10, 2)
  status         DoppelgangerStatus @default(inactive)
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  user           User               @relation(fields: [userId], references: [userId])
  transactions   PointTransaction[]

  @@map("cyber_doppelgangers")
}

model ActivityPeriod {
  periodId    BigInt   @id @default(autoincrement()) @map("period_id")
  startTime   DateTime @map("start_time")
  endTime     DateTime @map("end_time")
  rewardPool  Decimal  @default(5000) @map("reward_pool") @db.Decimal(10, 2)
  isProcessed Boolean  @default(false) @map("is_processed")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([startTime, endTime])
  @@map("activity_periods")
}

model PointTransaction {
  transactionId  BigInt            @id @default(autoincrement()) @map("transaction_id")
  doppelgangerId BigInt            @map("doppelganger_id")
  amount         Decimal           @db.Decimal(10, 2)
  type           PointTransType
  metadata       Json?
  createdAt      DateTime          @default(now()) @map("created_at")
  doppelganger   CyberDoppelganger @relation(fields: [doppelgangerId], references: [doppelgangerId])

  @@index([doppelgangerId])
  @@map("point_transactions")
}

model SignInRecord {
  recordId       BigInt   @id @default(autoincrement()) @map("record_id")
  userId         BigInt   @map("user_id")
  lastSignInDate DateTime @map("last_sign_in_date")
  streakDays     Int      @default(1) @map("streak_days")
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([userId, lastSignInDate])
  @@map("sign_in_records")
}


model BountyTask {
  taskId      BigInt           @id @default(autoincrement()) @map("task_id")
  title       String           @db.VarChar(100)
  content     String           @db.Text
  points      Decimal          @db.Decimal(10, 2)
  difficulty  TaskDifficulty   @default(MEDIUM)
  status      TaskStatus       @default(PUBLISHED)
  createdAt   DateTime         @default(now()) @map("created_at")
  submissions TaskSubmission[]

  @@map("bounty_tasks")
}

model TaskSubmission {
  submissionId BigInt           @id @default(autoincrement()) @map("submission_id")
  userId       BigInt           @map("user_id")
  taskId       BigInt           @map("task_id")
  proof        String?          @db.Text
  status       SubmissionStatus @default(PENDING)
  createdAt    DateTime         @default(now()) @map("created_at")
  task         BountyTask       @relation(fields: [taskId], references: [taskId])

  @@index([taskId])
  @@index([userId])
  @@map("task_submissions")
}

enum DoppelgangerStatus {
  active
  inactive
  frozen
}

enum PointTransType {
  INVITE_REWARD
  TASK_REWARD
  TOKEN_CONSUME
  SYSTEM_ADJUST
  INITIAL_BONUS
  DAILY_SIGN_IN
  CONTRIBUTION_REWARD
}

enum TaskStatus {
  PUBLISHED
  FINISHED
  CANCELLED
}

enum TaskDifficulty {
  EASY
  MEDIUM
  HARD
  EXPERT
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}


